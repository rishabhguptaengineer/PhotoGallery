<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="nav-vc-001">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <!--Navigation Controller-->
        <scene sceneID="scene-nav-001">
            <objects>
                <navigationController id="nav-vc-001" sceneMemberID="viewController">
                    <navigationBar key="navigationBar" contentMode="scaleToFill" id="nav-bar-001">
                        <rect key="frame" x="0.0" y="118" width="393" height="54"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <connections>
                        <segue destination="list-vc-001" kind="relationship" relationship="rootViewController" id="segue-nav-root"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="fr-nav-001" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="-600" y="100"/>
        </scene>
        <!--Photos-->
        <scene sceneID="scene-list-001">
            <objects>
                <viewController id="list-vc-001" customClass="PhotoListViewController" customModule="PhotoGallery" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="list-view-001">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <tableView clipsSubviews="YES" contentMode="scaleToFill" alwaysBounceVertical="YES" dataMode="prototypes" style="plain" separatorStyle="default" rowHeight="88" estimatedRowHeight="88" sectionHeaderHeight="22" sectionFooterHeight="22" translatesAutoresizingMaskIntoConstraints="NO" id="list-tv-001">
                                <rect key="frame" x="0.0" y="172" width="393" height="612"/>
                                <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                            </tableView>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="list-safe-001"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <constraints>
                            <constraint firstItem="list-safe-001" firstAttribute="bottom" secondItem="list-tv-001" secondAttribute="bottom" id="list-c-bot"/>
                            <constraint firstItem="list-tv-001" firstAttribute="leading" secondItem="list-safe-001" secondAttribute="leading" id="list-c-lead"/>
                            <constraint firstItem="list-tv-001" firstAttribute="top" secondItem="list-safe-001" secondAttribute="top" id="list-c-top"/>
                            <constraint firstItem="list-safe-001" firstAttribute="trailing" secondItem="list-tv-001" secondAttribute="trailing" id="list-c-trail"/>
                        </constraints>
                    </view>
                    <navigationItem key="navigationItem" title="Photos" id="list-nav-item-001"/>
                    <connections>
                        <outlet property="tableView" destination="list-tv-001" id="outlet-list-tv"/>
                        <segue destination="detail-vc-001" kind="show" identifier="ShowPhotoDetail" id="segue-show-detail"/>
                    </connections>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="fr-list-001" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="50" y="100"/>
        </scene>
        <!--Photo Detail-->
        <scene sceneID="scene-detail-001">
            <objects>
                <viewController id="detail-vc-001" customClass="PhotoDetailViewController" customModule="PhotoGallery" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="detail-view-001">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <scrollView clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="detail-sv-001">
                                <rect key="frame" x="0.0" y="172" width="393" height="612"/>
                                <subviews>
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="detail-content-001">
                                        <rect key="frame" x="0.0" y="0.0" width="393" height="438"/>
                                        <subviews>
                                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" translatesAutoresizingMaskIntoConstraints="NO" id="detail-img-001">
                                                <rect key="frame" x="16" y="20" width="361" height="220"/>
                                                <color key="backgroundColor" systemColor="secondarySystemBackgroundColor"/>
                                            </imageView>
                                            <textField opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" borderStyle="roundedRect" placeholder="Photo title" minimumFontSize="17" translatesAutoresizingMaskIntoConstraints="NO" id="detail-tf-001">
                                                <rect key="frame" x="16" y="260" width="361" height="34"/>
                                                <fontDescription key="fontDescription" type="system" pointSize="17"/>
                                                <textInputTraits key="textInputTraits" autocapitalizationType="sentences"/>
                                            </textField>
                                            <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="detail-save-btn">
                                                <rect key="frame" x="16" y="314" width="361" height="44"/>
                                                <state key="normal" title="Save"/>
                                                <connections>
                                                    <action selector="saveButtonTapped:" destination="detail-vc-001" eventType="touchUpInside" id="action-save"/>
                                                </connections>
                                            </button>
                                            <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="detail-del-btn">
                                                <rect key="frame" x="16" y="374" width="361" height="44"/>
                                                <state key="normal" title="Delete"/>
                                                <connections>
                                                    <action selector="deleteButtonTapped:" destination="detail-vc-001" eventType="touchUpInside" id="action-delete"/>
                                                </connections>
                                            </button>
                                        </subviews>
                                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                                        <constraints>
                                            <constraint firstItem="detail-img-001" firstAttribute="top" secondItem="detail-content-001" secondAttribute="top" constant="20" id="d-c1"/>
                                            <constraint firstAttribute="trailing" secondItem="detail-save-btn" secondAttribute="trailing" constant="16" id="d-c10"/>
                                            <constraint firstItem="detail-save-btn" firstAttribute="height" constant="44" id="d-c11"/>
                                            <constraint firstItem="detail-del-btn" firstAttribute="top" secondItem="detail-save-btn" secondAttribute="bottom" constant="16" id="d-c12"/>
                                            <constraint firstItem="detail-del-btn" firstAttribute="leading" secondItem="detail-content-001" secondAttribute="leading" constant="16" id="d-c13"/>
                                            <constraint firstAttribute="trailing" secondItem="detail-del-btn" secondAttribute="trailing" constant="16" id="d-c14"/>
                                            <constraint firstItem="detail-del-btn" firstAttribute="height" constant="44" id="d-c15"/>
                                            <constraint firstAttribute="bottom" secondItem="detail-del-btn" secondAttribute="bottom" constant="20" id="d-c16"/>
                                            <constraint firstItem="detail-img-001" firstAttribute="leading" secondItem="detail-content-001" secondAttribute="leading" constant="16" id="d-c2"/>
                                            <constraint firstAttribute="trailing" secondItem="detail-img-001" secondAttribute="trailing" constant="16" id="d-c3"/>
                                            <constraint firstItem="detail-img-001" firstAttribute="height" constant="220" id="d-c4"/>
                                            <constraint firstItem="detail-tf-001" firstAttribute="top" secondItem="detail-img-001" secondAttribute="bottom" constant="20" id="d-c5"/>
                                            <constraint firstItem="detail-tf-001" firstAttribute="leading" secondItem="detail-content-001" secondAttribute="leading" constant="16" id="d-c6"/>
                                            <constraint firstAttribute="trailing" secondItem="detail-tf-001" secondAttribute="trailing" constant="16" id="d-c7"/>
                                            <constraint firstItem="detail-save-btn" firstAttribute="top" secondItem="detail-tf-001" secondAttribute="bottom" constant="20" id="d-c8"/>
                                            <constraint firstItem="detail-save-btn" firstAttribute="leading" secondItem="detail-content-001" secondAttribute="leading" constant="16" id="d-c9"/>
                                        </constraints>
                                    </view>
                                </subviews>
                                <constraints>
                                    <constraint firstItem="detail-content-001" firstAttribute="top" secondItem="detail-sv-001" secondAttribute="top" id="sv-c1"/>
                                    <constraint firstItem="detail-content-001" firstAttribute="leading" secondItem="detail-sv-001" secondAttribute="leading" id="sv-c2"/>
                                    <constraint firstAttribute="trailing" secondItem="detail-content-001" secondAttribute="trailing" id="sv-c3"/>
                                    <constraint firstAttribute="bottom" secondItem="detail-content-001" secondAttribute="bottom" id="sv-c4"/>
                                    <constraint firstItem="detail-content-001" firstAttribute="width" secondItem="detail-sv-001" secondAttribute="width" id="sv-c5"/>
                                </constraints>
                            </scrollView>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="detail-safe-001"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <constraints>
                            <constraint firstItem="detail-sv-001" firstAttribute="top" secondItem="detail-safe-001" secondAttribute="top" id="root-c1"/>
                            <constraint firstItem="detail-sv-001" firstAttribute="leading" secondItem="detail-safe-001" secondAttribute="leading" id="root-c2"/>
                            <constraint firstItem="detail-safe-001" firstAttribute="trailing" secondItem="detail-sv-001" secondAttribute="trailing" id="root-c3"/>
                            <constraint firstItem="detail-safe-001" firstAttribute="bottom" secondItem="detail-sv-001" secondAttribute="bottom" id="root-c4"/>
                        </constraints>
                    </view>
                    <navigationItem key="navigationItem" title="Photo Detail" id="detail-nav-item-001"/>
                    <connections>
                        <outlet property="deleteButton" destination="detail-del-btn" id="outlet-detail-del"/>
                        <outlet property="imageView" destination="detail-img-001" id="outlet-detail-img"/>
                        <outlet property="saveButton" destination="detail-save-btn" id="outlet-detail-save"/>
                        <outlet property="titleTextField" destination="detail-tf-001" id="outlet-detail-tf"/>
                    </connections>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="fr-detail-001" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="700" y="100"/>
        </scene>
    </scenes>
    <resources>
        <systemColor name="secondarySystemBackgroundColor">
            <color red="0.94901960784313721" green="0.94901960784313721" blue="0.96862745098039216" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
    </resources>
</document>
