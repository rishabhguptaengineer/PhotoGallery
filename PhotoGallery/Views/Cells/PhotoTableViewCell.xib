<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23502"/>
        <capability name="System colors in document" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <tableViewCell contentMode="scaleToFill" selectionStyle="default" indentationWidth="10" reuseIdentifier="PhotoTableViewCell" id="cell-root" customClass="PhotoTableViewCell" customModule="PhotoGallery" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="88"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <tableViewCellContentView key="contentView" opaque="YES" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" tableViewCell="cell-root" id="cell-content">
                <rect key="frame" x="0.0" y="0.0" width="375" height="88"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="thumb-img">
                        <rect key="frame" x="12" y="8" width="72" height="72"/>
                        <color key="backgroundColor" systemColor="secondarySystemBackgroundColor"/>
                    </imageView>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Title" lineBreakMode="wordWrap" numberOfLines="2" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title-lbl">
                        <rect key="frame" x="96" y="24" width="263" height="40"/>
                        <fontDescription key="fontDescription" type="system" pointSize="15"/>
                        <nil key="textColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                </subviews>
                <constraints>
                    <constraint firstItem="thumb-img" firstAttribute="leading" secondItem="cell-content" secondAttribute="leading" constant="12" id="c1"/>
                    <constraint firstItem="thumb-img" firstAttribute="centerY" secondItem="cell-content" secondAttribute="centerY" id="c2"/>
                    <constraint firstItem="thumb-img" firstAttribute="width" secondAttribute="notAnAttribute" constant="72" id="c3"/>
                    <constraint firstItem="thumb-img" firstAttribute="height" secondAttribute="notAnAttribute" constant="72" id="c4"/>
                    <constraint firstItem="title-lbl" firstAttribute="leading" secondItem="thumb-img" secondAttribute="trailing" constant="12" id="c5"/>
                    <constraint firstItem="title-lbl" firstAttribute="centerY" secondItem="cell-content" secondAttribute="centerY" id="c6"/>
                    <constraint firstItem="cell-content" firstAttribute="trailing" secondItem="title-lbl" secondAttribute="trailing" constant="12" id="c7"/>
                </constraints>
            </tableViewCellContentView>
            <connections>
                <outlet property="thumbnailImageView" destination="thumb-img" id="outlet-thumb"/>
                <outlet property="titleLabel" destination="title-lbl" id="outlet-title"/>
            </connections>
        </tableViewCell>
    </objects>
</document>
